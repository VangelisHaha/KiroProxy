# ==============================================================================
# KiroProxy Configuration
# Copy this file to .env and modify as needed
# ==============================================================================

# Server settings
# KIRO_SERVER_HOST=0.0.0.0
# KIRO_SERVER_PORT=8080

# VPN/Proxy for Kiro API access (useful in China or corporate networks)
# Supports HTTP and SOCKS5 protocols
# KIRO_VPN_PROXY_URL=http://127.0.0.1:7890
# KIRO_VPN_PROXY_URL=socks5://127.0.0.1:1080
# KIRO_VPN_PROXY_URL=http://user:password@proxy.company.com:8080

# Kiro API region
# KIRO_REGION=us-east-1
# KIRO_API_REGION=us-east-1

# Authentication - kiro-cli SQLite database (recommended)
# KIRO_CLI_DB_FILE=~/.local/share/kiro-cli/data.sqlite3
# KIRO_SQLITE_READONLY=false

# Authentication - JSON credentials file
# KIRO_CREDS_FILE=/path/to/credentials.json

# Token refresh threshold (seconds before expiration)
# KIRO_TOKEN_REFRESH_THRESHOLD=600

# Retry configuration
# KIRO_MAX_RETRIES=3
# KIRO_BASE_RETRY_DELAY=1.0

# Payload guard (Kiro API rejects payloads > ~615KB)
# KIRO_MAX_PAYLOAD_BYTES=600000
# KIRO_AUTO_TRIM_PAYLOAD=true

# Truncation recovery (inject synthetic messages on truncation)
# KIRO_TRUNCATION_RECOVERY=true

# Extended thinking
# KIRO_THINKING_ENABLED=true
# KIRO_THINKING_MAX_TOKENS=4000
# KIRO_THINKING_BUDGET_CAP=10000
# KIRO_THINKING_HANDLING=as_reasoning_content
# Options: as_reasoning_content, remove, pass, strip_tags

# Streaming timeouts
# KIRO_FIRST_TOKEN_TIMEOUT=15
# KIRO_STREAMING_READ_TIMEOUT=300
# KIRO_FIRST_TOKEN_MAX_RETRIES=3

# Model cache TTL (seconds)
# KIRO_MODEL_CACHE_TTL=3600

# Logging
# KIRO_LOG_LEVEL=INFO
# KIRO_LOG_FILE=logs/kiro_proxy.log
# KIRO_LOG_MAX_SIZE=10 MB
# KIRO_LOG_RETENTION=7 days
# KIRO_DEBUG_MODE=off
# Options: off, errors, all

# Rate limiting
# KIRO_RATE_LIMIT_MIN_INTERVAL=0
# KIRO_RATE_LIMIT_PER_ACCOUNT_RPM=0
# KIRO_RATE_LIMIT_GLOBAL_RPM=0

# Circuit breaker
# KIRO_CB_RECOVERY_TIMEOUT=60
# KIRO_CB_MAX_BACKOFF=1440.0
# KIRO_CB_RETRY_CHANCE=0.1

# Web search
# KIRO_WEB_SEARCH_ENABLED=true

# UI language
# KIRO_UI_LANGUAGE=zh
